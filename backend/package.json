{
  "name": "wdp301-backend",
  "version": "0.1.0",
  "description": "NestJS backend for WDP301 enterprise platform",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/wdp301-backend/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "// --- MICROSERVICES COMMANDS ---": "",
    "start:gateway": "npx ts-node --transpile-only -r tsconfig-paths/register apps/api-gateway/src/main.ts",
    "start:auth": "npx ts-node --transpile-only -r tsconfig-paths/register apps/auth-service/src/main.ts",
    "start:user": "npx ts-node --transpile-only -r tsconfig-paths/register apps/user-service/src/main.ts",
    "start:inventory": "npx ts-node --transpile-only -r tsconfig-paths/register apps/inventory-service/src/main.ts",
    "start:supplier": "npx ts-node --transpile-only -r tsconfig-paths/register apps/supplier-service/src/main.ts",
    "dev:all": "npx concurrently \"npm run start:gateway\" \"npm run start:auth\" \"npm run start:user\" \"npm run start:inventory\" \"npm run start:supplier\"",
    "inspect": "ts-node --transpile-only scripts/inspect-db.ts",
    "db:clean-medicines": "ts-node --transpile-only scripts/clean-medicines.ts",
    "db:seed-prescriptions": "ts-node --transpile-only scripts/seed-prescriptions.ts",
    "// --- INFRASTRUCTURE ---": "",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "infra:logs": "docker-compose logs -f kafka redis"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.22",
    "@nestjs/mongoose": "^10.0.4",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/typeorm": "^10.0.2",
    "@supabase/supabase-js": "^2.106.2",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^5.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "concurrently": "^9.2.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "kafkajs": "^2.2.4",
    "mongodb": "^7.3.0",
    "mongoose": "^8.2.3",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.30",
    "wdp301-workspace": "file:.."
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
